{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "laflamme-site",
  "main": "src/worker.js",
  "compatibility_date": "2025-09-27",
  "observability": {
    "enabled": true
  },
  "assets": {
    "directory": ".",
    "exclude": ["src"]
  },
  "compatibility_flags": [
    "nodejs_compat"
  ]
}
